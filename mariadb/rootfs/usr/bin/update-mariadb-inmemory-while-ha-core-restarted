app_slug=45207088_mariadb
app_name="In-memory MariaDB"
set -e
if ha apps info ${app_slug} --raw-json | jq -rce '.data.version == .data.version_latest' > /dev/null; then
  echo "You already have the latest ${app_name} app installed!"
else
  echo "Stopping HA core..."
  ha core stop
  echo -e "\nUpdating ${app_name} app..."
  ha apps update ${app_slug} --backup
  echo -e "\nStarting HA core..."
  ha core start
fi
